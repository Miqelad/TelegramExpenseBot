POSTGRES_DB=expenses
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

EXPENSE_DB_USER=expense_user
EXPENSE_DB_PASSWORD=change_me_too

TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_RESPONSE_CHAT_ID=
TELEGRAM_RESPONSE_THREAD_ID=

# Ключ Gemini API из Google AI Studio. Заменяет старые GROQ_API_KEY и JINA_API_KEY.
GEMINI_API_KEY=your_gemini_api_key

# Модели Gemini для текстовых ответов, через запятую.
# Если первая модель недоступна и вернула 404, бот попробует следующую.
GEMINI_CHAT_MODELS=gemini-3.1-flash-lite,gemini-3.1-flash-lite-preview

# Модель Gemini для embedding-векторов расходов и semantic search.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Размерность embedding-вектора. Оставь 1024, пока колонка БД имеет тип vector(1024).
GEMINI_EMBEDDING_DIMENSIONS=1024

# Максимальное число попыток одного запроса embedding, включая первую попытку.
GEMINI_EMBEDDING_RETRY_MAX_ATTEMPTS=5

# Базовая пауза перед повтором embedding-запроса после 429, в миллисекундах.
GEMINI_EMBEDDING_RETRY_BASE_DELAY_MS=5000

# Максимальная пауза перед повтором embedding-запроса после 429, в миллисекундах.
GEMINI_EMBEDDING_RETRY_MAX_DELAY_MS=60000

# Максимальное число попыток идемпотентной записи embedding в таблицу, включая первую попытку.
DB_WRITE_RETRY_MAX_ATTEMPTS=3

# Пауза между повторами записи embedding в БД, в миллисекундах.
DB_WRITE_RETRY_DELAY_MS=1000
